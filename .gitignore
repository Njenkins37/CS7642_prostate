# Python environments.
.venv/
env/
__pycache__/
mise.toml
.vscode/

# Ignore dot-directories in repo root
.*/
# But keep the root .git files
!.gitignore
!.gitkeep
!.gitattributes

# Data, Images and Labels.
*.npz
*.png
inputs/*
!inputs/images/.gitkeep
!inputs/labels/.gitkeep
outputs/*
!outputs/.gitkeep

# OS generated files.
.DS_Store

!*.gitkeep
